// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum UserRole {
  volunteer
  organizer
  admin
}

enum UserStatus {
  active
  inactive
  blocked
  deleted
}

enum VerificationStatus {
  pending
  verified
  rejected
  blocked
}

enum ProjectStatus {
  draft       // Черновик
  moderation  // На модерации у админа
  rejected    // Отклонен админом
  recruiting  // Опубликован, идет набор волонтеров
  upcoming    // Набор завершен, проект скоро начнется
  active      // Проект идет
  completed   // Проект завершен
  cancelled   // Проект отменен
  blocked     // Заблокирован админом
}

enum TaskStatus {
  pending
  in_progress
  completed
  overdue
  cancelled
}

enum TaskAssignmentStatus {
  assigned
  completed
  confirmed
  rejected
  cancelled
}

enum ApplicationStatus {
  pending
  approved
  rejected
  cancelled
}

enum ConditionType {
  projects_count
  category_projects_count
  perfect_month
  organizer
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum MessageSender {
  user
  ai
}

enum NotificationType {
  comment_reply
  new_project
  application_status
}

enum Language {
  ru
  kg
}

// Models
model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique @db.VarChar(255)
  phone         String     @unique @db.VarChar(20)
  passwordHash  String     @map("password_hash") @db.VarChar(255)
  role          UserRole
  firstName     String     @map("first_name") @db.VarChar(100)
  lastName      String     @map("last_name") @db.VarChar(100)
  city          String     @db.VarChar(100)
  avatarUrl     String?    @map("avatar_url")
  status        UserStatus @default(active)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamp(6)

  volunteerProfile    VolunteerProfile?
  organizerProfile    OrganizerProfile?
  skills              UserSkill[]
  interests           Interest[]
  projects            Project[]
  taskAssignments     TaskAssignment[]     @relation("VolunteerAssignments")
  assignedTasks       TaskAssignment[]     @relation("AssignedBy")
  applications        Application[]
  reviewedApplications Application[]       @relation("ReviewedBy")
  projectParticipants ProjectParticipant[] @relation("VolunteerParticipants")
  achievements        UserAchievement[]
  payments            Payment[]
  aiChats             AiChat[]
  chatMemberships     ProjectChatMember[]
  chatMessages        ProjectChatMessage[] @relation("ChatMessageSender")
  directChatsAsUser1  DirectChat[]         @relation("DirectChatUser1")
  directChatsAsUser2  DirectChat[]         @relation("DirectChatUser2")
  directMessages      DirectMessage[]      @relation("DirectMessageSender")
  calendarEvents      CalendarEvent[]
  projectComments     ProjectComment[]
  notifications       Notification[]

  @@map("users")
}

model VolunteerProfile {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  bio               String?
  availableTime     Json?    @map("available_time")
  trustScore        Decimal  @default(0) @map("trust_score") @db.Decimal(5, 2)
  ratingCount       Int      @default(0) @map("rating_count")
  completedTasks    Int      @default(0) @map("completed_tasks")
  completedProjects Int      @default(0) @map("completed_projects")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("volunteer_profiles")
}

model OrganizerProfile {
  id                   String              @id @default(uuid()) @db.Uuid
  userId               String              @unique @map("user_id") @db.Uuid
  organizationName     String              @map("organization_name") @db.VarChar(255)
  inn                  String              @db.VarChar(14)
  okpo                 String              @db.VarChar(8)
  legalAddress         String              @map("legal_address")
  actualAddress        String              @map("actual_address")
  verificationStatus   VerificationStatus  @default(pending) @map("verification_status")
  verificationDocUrl   String?             @map("verification_doc_url")
  verificationComment  String?             @map("verification_comment")
  verifiedAt           DateTime?           @map("verified_at") @db.Timestamp(6)
  freePostsRemaining   Int                 @default(3) @map("free_posts_remaining")
  totalPaidPosts       Int                 @default(0) @map("total_paid_posts")
  isApprovedByAdmin    Boolean             @default(false) @map("is_approved_by_admin")
  approvedAt           DateTime?           @map("approved_at") @db.Timestamp(6)
  isRejected           Boolean             @default(false) @map("is_rejected")
  rejectedAt           DateTime?           @map("rejected_at") @db.Timestamp(6)
  rejectionReason      String?             @map("rejection_reason")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("organizer_profiles")
}

model Skill {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique @db.VarChar(100)

  users        UserSkill[]
  tasks        Task[]
  translations SkillTranslation[]

  @@map("skills")
}

model SkillTranslation {
  id       String   @id @default(uuid()) @db.Uuid
  skillId  String   @map("skill_id") @db.Uuid
  locale   Language
  name     String   @db.VarChar(255)

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, locale])
  @@map("skill_translations")
}

model UserSkill {
  userId  String @map("user_id") @db.Uuid
  skillId String @map("skill_id") @db.Uuid

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model Interest {
  userId     String @map("user_id") @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, categoryId])
  @@map("interests")
}

model Category {
  id   String @id @default(uuid()) @db.Uuid
  slug String @db.VarChar(100)
  icon String @db.Text

  interests    Interest[]
  projects     Project[]
  translations CategoryTranslation[]

  @@map("categories")
}

model CategoryTranslation {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  locale     Language
  name       String   @db.VarChar(255)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("category_translations")
}

model Project {
  id                String        @id @default(uuid()) @db.Uuid
  organizerId       String        @map("organizer_id") @db.Uuid
  title             String        @db.VarChar(255)
  description       String
  categoryId        String        @map("category_id") @db.Uuid
  startDate         DateTime      @map("start_date") @db.Date
  endDate           DateTime      @map("end_date") @db.Date
  location          String        @db.VarChar(255)
  latitude          Decimal?      @db.Decimal(10, 8)
  longitude         Decimal?      @db.Decimal(11, 8)
  maxVolunteers     Int           @map("max_volunteers")
  currentVolunteers Int           @default(0) @map("current_volunteers")
  status            ProjectStatus @default(draft)
  rejectionReason   String?       @map("rejection_reason")
  isPaid            Boolean       @default(false) @map("is_paid")
  paymentId         String?       @unique @map("payment_id") @db.Uuid
  publishedAt       DateTime?     @map("published_at") @db.Timestamp(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  moderatedAt       DateTime?     @map("moderated_at") @db.Timestamp(6)
  moderatedBy       String?       @map("moderated_by") @db.Uuid
  imageUrl          String?       @map("image_url")

  organizer    User                 @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  category     Category             @relation(fields: [categoryId], references: [id])
  payment      Payment?             @relation(fields: [paymentId], references: [id])
  tasks        Task[]
  applications Application[]
  participants ProjectParticipant[]
  chat         ProjectChat?
  comments     ProjectComment[]

  @@map("projects")
}

model Task {
  id                  String     @id @default(uuid()) @db.Uuid
  projectId           String     @map("project_id") @db.Uuid
  title               String     @db.VarChar(255)
  description         String
  requiredSkillId     String?    @map("required_skill_id") @db.Uuid
  requiredVolunteers  Int        @map("required_volunteers")
  currentVolunteers   Int        @default(0) @map("current_volunteers")
  deadline            DateTime   @db.Date
  status              TaskStatus @default(pending)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamp(6)

  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skill          Skill?           @relation(fields: [requiredSkillId], references: [id])
  assignments    TaskAssignment[]
  applications   Application[]
  calendarEvents CalendarEvent[]

  @@map("tasks")
}

model TaskAssignment {
  id          String                 @id @default(uuid()) @db.Uuid
  taskId      String                 @map("task_id") @db.Uuid
  volunteerId String                 @map("volunteer_id") @db.Uuid
  assignedBy  String                 @map("assigned_by") @db.Uuid
  status      TaskAssignmentStatus   @default(assigned)
  completedAt DateTime?              @map("completed_at") @db.Timestamp(6)
  confirmedAt DateTime?              @map("confirmed_at") @db.Timestamp(6)
  feedback    String?
  rating      Int?
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamp(6)

  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  volunteer User @relation("VolunteerAssignments", fields: [volunteerId], references: [id], onDelete: Cascade)
  assigner  User @relation("AssignedBy", fields: [assignedBy], references: [id])
  report    TaskReport?

  @@unique([taskId, volunteerId])
  @@map("task_assignments")
}

model TaskReport {
  id           String   @id @default(uuid()) @db.Uuid
  assignmentId String   @unique @map("assignment_id") @db.Uuid
  description  String
  photos       String[] // Массив URL фотографий
  submittedAt  DateTime @default(now()) @map("submitted_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  assignment TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("task_reports")
}

model ProjectParticipant {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  volunteerId String    @map("volunteer_id") @db.Uuid
  joinedAt    DateTime  @default(now()) @map("joined_at") @db.Timestamp(6)
  leftAt      DateTime? @map("left_at") @db.Timestamp(6)
  isActive    Boolean   @default(true) @map("is_active")
  notes       String?   // Заметки организатора о волонтере

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  volunteer User    @relation("VolunteerParticipants", fields: [volunteerId], references: [id], onDelete: Cascade)

  @@unique([projectId, volunteerId])
  @@map("project_participants")
}

model Application {
  id              String            @id @default(uuid()) @db.Uuid
  projectId       String            @map("project_id") @db.Uuid
  volunteerId     String            @map("volunteer_id") @db.Uuid
  taskId          String?           @map("task_id") @db.Uuid // Deprecated: оставлено для обратной совместимости
  message         String?
  status          ApplicationStatus @default(pending)
  reviewedBy      String?           @map("reviewed_by") @db.Uuid
  reviewedAt      DateTime?         @map("reviewed_at") @db.Timestamp(6)
  rejectionReason String?           @map("rejection_reason")
  appliedAt       DateTime          @default(now()) @map("applied_at") @db.Timestamp(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamp(6)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  volunteer User    @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  task      Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  reviewer  User?   @relation("ReviewedBy", fields: [reviewedBy], references: [id])

  @@unique([projectId, volunteerId])
  @@map("applications")
}

model Achievement {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @db.VarChar(100)
  description    String
  icon           String        @db.Text
  conditionType  ConditionType @map("condition_type")
  conditionValue Int           @map("condition_value")
  isActive       Boolean       @default(true) @map("is_active")

  rewards          AchievementReward[]
  userAchievements UserAchievement[]
  translations     AchievementTranslation[]

  @@map("achievements")
}

model AchievementTranslation {
  id            String   @id @default(uuid()) @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  locale        Language
  name          String   @db.VarChar(255)
  description   String

  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([achievementId, locale])
  @@map("achievement_translations")
}

model AchievementReward {
  id            String  @id @default(uuid()) @db.Uuid
  achievementId String  @map("achievement_id") @db.Uuid
  partnerId     String  @map("partner_id") @db.Uuid
  rewardText    String  @map("reward_text") @db.VarChar(255)
  validForDays  Int     @map("valid_for_days")
  isActive      Boolean @default(true) @map("is_active")

  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  partner     Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("achievement_rewards")
}

model Partner {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @db.VarChar(255)
  logoUrl     String? @map("logo_url")
  contactInfo String? @map("contact_info")
  isActive    Boolean @default(true) @map("is_active")

  rewards AchievementReward[]

  @@map("partners")
}

model UserAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  rewardText    String   @map("reward_text") @db.VarChar(255)
  expiresAt     DateTime @map("expires_at") @db.Timestamp(6)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@map("user_achievements")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  projectId       String?       @map("project_id") @db.Uuid
  finikPaymentId  String        @map("finik_payment_id") @db.VarChar(255)
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(pending)
  paymentMethod   String        @map("payment_method") @db.VarChar(50)
  callbackData    Json?         @map("callback_data")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  paidAt          DateTime?     @map("paid_at") @db.Timestamp(6)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("payments")
}

model AiChat {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user     User?       @relation(fields: [userId], references: [id])
  messages AiMessage[]

  @@map("ai_chats")
}

model AiMessage {
  id        String        @id @default(uuid()) @db.Uuid
  chatId    String        @map("chat_id") @db.Uuid
  sender    MessageSender
  message   String
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)

  chat AiChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model PasswordResetToken {
  email     String   @id @db.VarChar(255)
  code      String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  email               String   @id @db.VarChar(255)
  code                String   @db.VarChar(6)
  passwordHash        String   @map("password_hash") @db.VarChar(255)
  role                UserRole
  firstName           String   @map("first_name") @db.VarChar(100)
  lastName            String   @map("last_name") @db.VarChar(100)
  phone               String   @db.VarChar(20)
  city                String   @db.VarChar(100)
  organizationName    String?  @map("organization_name") @db.VarChar(255)
  inn                 String?  @db.VarChar(14)
  okpo                String?  @db.VarChar(8)
  legalAddress        String?  @map("legal_address")
  actualAddress       String?  @map("actual_address")
  verificationDocUrl  String?  @map("verification_doc_url")
  expiresAt           DateTime @map("expires_at") @db.Timestamp(6)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("email_verification_tokens")
}

model Setting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique @db.VarChar(255)
  value String

  @@map("settings")
}

model ProjectChat {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @unique @map("project_id") @db.Uuid
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  project  Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members  ProjectChatMember[]
  messages ProjectChatMessage[]

  @@map("project_chats")
}

model ProjectChatMember {
  chatId   String   @map("chat_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamp(6)

  chat ProjectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([chatId, userId])
  @@map("project_chat_members")
}

model ProjectChatMessage {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @map("chat_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  content     String
  deliveredTo String[] @default([]) @map("delivered_to") @db.Uuid
  readBy      String[] @default([]) @map("read_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  chat   ProjectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User        @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("project_chat_messages")
}

// Личные чаты между пользователями (организатор <-> волонтер)
model DirectChat {
  id        String   @id @default(uuid()) @db.Uuid
  user1Id   String   @map("user1_id") @db.Uuid
  user2Id   String   @map("user2_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user1    User            @relation("DirectChatUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User            @relation("DirectChatUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([user1Id, user2Id])
  @@map("direct_chats")
}

model DirectMessage {
  id          String   @id @default(uuid()) @db.Uuid
  chatId      String   @map("chat_id") @db.Uuid
  senderId    String   @map("sender_id") @db.Uuid
  content     String
  deliveredTo String[] @default([]) @map("delivered_to") @db.Uuid
  readBy      String[] @default([]) @map("read_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  chat   DirectChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User       @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("direct_messages")
}

model ProjectComment {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  text      String
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  ProjectComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies ProjectComment[] @relation("CommentReplies")

  @@map("project_comments")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String
  link      String?          @db.VarChar(500)
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model CalendarEvent {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  startTime   String?  @map("start_time") @db.VarChar(5)
  endTime     String?  @map("end_time") @db.VarChar(5)
  color       String   @default("#00CC00") @db.VarChar(20)
  isAllDay    Boolean  @default(true) @map("is_all_day")
  location    String?  @db.VarChar(255)
  taskId      String?  @map("task_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("calendar_events")
}
